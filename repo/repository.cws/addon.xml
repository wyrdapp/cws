<?xml version="1.0" encoding="UTF-8"?>
<addon id="repository.cws"
       name="CWS Repository"
       version="1.0.0"
       provider-name="wyrdapp">
  <requires>
    <import addon="xbmc.addon" version="12.0.0"/>
  </requires>
  <extension point="xbmc.addon.repository" name="CWS Repository">
    <dir>
      <info compressed="false">https://raw.githubusercontent.com/wyrdapp/cws/main/repo/addons.xml</info>
      <checksum>https://raw.githubusercontent.com/wyrdapp/cws/main/repo/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/wyrdapp/cws/main/repo</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary>CWS - Cinema addon repository</summary>
    <description>Repository for Cinema streaming addons.</description>
    <platform>all</platform>
    <license>MIT</license>
  </extension>
</addon>
