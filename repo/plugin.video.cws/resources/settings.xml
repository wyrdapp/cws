<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<settings>
  <category label="Zdroje">
    <setting label="Webshare (vyžaduje VIP účet)" type="bool" id="webshare_enabled" default="true"/>
    <setting label="  Uživatelské jméno" type="text" id="webshare_username" default=""
             enable="eq(-1,true)"/>
    <setting label="  Heslo" type="text" id="webshare_password" option="hidden" default=""
             enable="eq(-2,true)"/>
    <setting label="Hellspy (zdarma, bez přihlášení)" type="bool" id="hellspy_enabled" default="true"/>
    <setting label="Real-Debrid (prémiové torrenty)" type="bool" id="rd_enabled" default="false"/>
    <setting label="  API klíč (real-debrid.com/apitoken)" type="text" id="rd_api_key" default=""
             enable="eq(-1,true)"/>
    <setting label="TorBox (prémiové torrenty, má cache check)" type="bool" id="tb_enabled" default="false"/>
    <setting label="  API klíč (torbox.app/settings)" type="text" id="tb_api_key" default=""
             enable="eq(-1,true)"/>
  </category>
  <category label="Předvolby">
    <setting label="Preferovaný jazyk" type="select" id="preferred_language"
             values="CS|SK|EN|Vše" default="0"/>
    <setting label="Minimální kvalita" type="select" id="min_quality"
             values="Vše|720p|1080p|2160p" default="0"/>
    <setting label="Max. počet streamů" type="select" id="max_results"
             values="10|15|25" default="1"/>
    <setting label="Automaticky přehrát nejlepší stream" type="bool"
             id="auto_play_best" default="false"/>
    <setting label="TMDB API klíč" type="text" id="tmdb_api_key" default=""/>
  </category>
  <category label="Titulky">
    <setting label="OpenSubtitles (automatické titulky)" type="bool" id="opensubtitles_enabled" default="false"/>
    <setting label="  API klíč (opensubtitles.com/consumers)" type="text" id="opensubtitles_api_key" default=""
             enable="eq(-1,true)"/>
    <setting label="  Uživatelské jméno (volitelné)" type="text" id="opensubtitles_username" default=""
             enable="eq(-2,true)"/>
    <setting label="  Heslo (volitelné)" type="text" id="opensubtitles_password" option="hidden" default=""
             enable="eq(-3,true)"/>
    <setting label="  Jazyky titulků (cs,sk,en)" type="text" id="subtitle_languages" default="cs,sk,en"
             enable="eq(-4,true)"/>
  </category>
  <category label="Stahování">
    <setting label="Povolit stahování" type="bool" id="download_enabled" default="false"/>
    <setting label="Složka pro stažené soubory" type="folder" id="download_folder"
             source="auto" default="" option="writeable"
             enable="eq(-1,true)"/>
  </category>
</settings>
