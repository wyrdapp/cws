<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<settings>
  <category label="Webshare účet">
    <setting label="Uživatelské jméno" type="text" id="webshare_username" default=""/>
    <setting label="Heslo" type="text" id="webshare_password" option="hidden" default=""/>
    <setting label="TMDB API klíč" type="text" id="tmdb_api_key" default=""/>
  </category>
  <category label="Předvolby">
    <setting label="Preferovaný jazyk" type="select" id="preferred_language"
             values="CS|SK|EN|Vše" default="0"/>
    <setting label="Minimální kvalita" type="select" id="min_quality"
             values="Vše|720p|1080p|2160p" default="0"/>
    <setting label="Max. počet streamů" type="select" id="max_results"
             values="10|15|25" default="1"/>
    <setting label="Automaticky přehrát nejlepší stream" type="bool"
             id="auto_play_best" default="false"/>
  </category>
  <category label="Stahování">
    <setting label="Složka pro stažené soubory" type="folder" id="download_folder"
             source="auto" default="" option="writeable"/>
  </category>
</settings>
